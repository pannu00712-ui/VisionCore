<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package
    Name="VisionCore"
    Manufacturer="VisionCore"
    Version="$(var.ProductVersion).0"
    UpgradeCode="E4A7C2D1-8F3B-4E9A-B6C0-12D3E5F7A801"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perMachine">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of VisionCore is already installed."
      Schedule="afterInstallInitialize"
      AllowDowngrades="no"
      AllowSameVersionUpgrades="no" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Launch Condition="VersionNT &gt;= 603" Message="VisionCore requires Windows 10 or later." />
    <Launch Condition="NOT MsiSystemRebootPending" Message="A system restart is pending. Please restart and run Setup again." />

    <!-- .NET 8 Desktop check via folder existence -->
    <Property Id="DOTNET8_DESKTOP_INSTALLED">
      <DirectorySearch Id="SearchDotNet8Folder" Path="[ProgramFiles64Folder]dotnet\shared\Microsoft.WindowsDesktop.App" Depth="1">
        <DirectorySearch Id="SearchDotNet8SubFolder" AssignToProperty="yes" SelectAllSubFolders="no" />
      </DirectorySearch>
    </Property>

    <Launch Condition="DOTNET8_DESKTOP_INSTALLED" Message="VisionCore requires .NET 8 Windows Desktop Runtime. Install from https://dotnet.microsoft.com/download/dotnet/8.0" />

    <Property Id="INSTALLDIR_FROM_REGISTRY">
      <RegistrySearch Id="SearchInstallDir" Root="HKLM"
        Key="SOFTWARE\VisionCore" Name="InstallPath" Type="raw" />
    </Property>

    <Property Id="WIXUI_INSTALLDIR"          Value="INSTALLDIR" />
    <Property Id="INSTALL_SERVICE"           Value="1" />
    <Property Id="AUTOSTART_SERVICE"         Value="1" />
    <Property Id="ADD_FIREWALL_RULE"         Value="1" />
    <Property Id="CREATE_DESKTOP_SHORTCUT"   Value="1" />
    <Property Id="CREATE_STARTMENU_SHORTCUT" Value="1" />

    <SetProperty Id="INSTALLDIR" Value="[INSTALLDIR_FROM_REGISTRY]"
      After="AppSearch" Sequence="execute" Condition="INSTALLDIR_FROM_REGISTRY" />

    <InstallExecuteSequence>
      <Custom Action="StopVisionCoreService"    Before="InstallFiles"
              Condition="((NOT UPGRADINGPRODUCTCODE) AND (REMOVE~=&quot;ALL&quot;)) OR UPGRADINGPRODUCTCODE"
              Overridable="yes" />
      <Custom Action="InstallVisionCoreService" After="InstallFiles"
              Condition="INSTALL_SERVICE AND (NOT REMOVE)" />
      <Custom Action="StartVisionCoreService"   After="InstallVisionCoreService"
              Condition="AUTOSTART_SERVICE AND INSTALL_SERVICE AND (NOT REMOVE)" />
      <Custom Action="RemoveVisionCoreService"  Before="RemoveFiles"
              Condition="REMOVE~=&quot;ALL&quot; AND (NOT UPGRADINGPRODUCTCODE)" />
    </InstallExecuteSequence>

    <CustomAction Id="InstallVisionCoreService" Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe create VisionCoreService binPath= &quot;[INSTALLDIR_SERVICE]VisionCore.Service.exe&quot; start= auto DisplayName= &quot;VisionCore Streaming Engine&quot;"
      Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="StartVisionCoreService" Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe start VisionCoreService"
      Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="StopVisionCoreService" Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe stop VisionCoreService"
      Execute="deferred" Impersonate="no" Return="ignore" />
    <CustomAction Id="RemoveVisionCoreService" Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe delete VisionCoreService"
      Execute="deferred" Impersonate="no" Return="ignore" />

    <Property Id="ARPPRODUCTICON" Value="VisionCoreIcon" />
    <Icon Id="VisionCoreIcon" SourceFile="$(var.SourceDir)\app\VisionCore.WPF.exe" />

  </Package>

  <Fragment>
    <ComponentGroup Id="RegistryEntries" Directory="TARGETDIR">
      <Component Id="RegInstallPath" Guid="A3C1D2E4-F5B6-7890-ABCD-EF1234567890">
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="InstallPath"  Type="string" Value="[INSTALLDIR]"          KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="Version"      Type="string" Value="$(var.ProductVersion)" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="ServiceName"  Type="string" Value="VisionCoreService" />
        <fw:FirewallException Id="FwRtsp"  Name="VisionCore RTSP (8554)"     Port="8554" Protocol="tcp" Scope="any"         IgnoreFailure="yes" />
        <fw:FirewallException Id="FwRest"  Name="VisionCore REST API (7880)" Port="7880" Protocol="tcp" Scope="localSubnet" IgnoreFailure="yes" />
        <fw:FirewallException Id="FwOnvif" Name="VisionCore ONVIF (8080)"    Port="8080" Protocol="tcp" Scope="any"         IgnoreFailure="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>

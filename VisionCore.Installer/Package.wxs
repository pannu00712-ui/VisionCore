<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package
    Name="VisionCore"
    Manufacturer="VisionCore"
    Version="$(var.ProductVersion)"
    UpgradeCode="E4A7C2D1-8F3B-4E9A-B6C0-12D3E5F7A801"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perMachine">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of VisionCore is already installed."
      Schedule="afterInstallInitialize"
      AllowDowngrades="no"
      AllowSameVersionUpgrades="no" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <Property Id="INSTALL_SERVICE"           Value="1" />
    <Property Id="AUTOSTART_SERVICE"         Value="1" />
    <Property Id="ADD_FIREWALL_RULE"         Value="1" />
    <Property Id="CREATE_DESKTOP_SHORTCUT"   Value="1" />
    <Property Id="CREATE_STARTMENU_SHORTCUT" Value="1" />

    <!-- Service install/start/stop/remove is now handled by the native
         ServiceInstall/ServiceControl elements on the VisionCoreServiceExe
         component in Directories.wxs, instead of raw sc.exe CustomActions.
         The previous CustomAction approach (ExeCommand="[SystemFolder]sc.exe...")
         combined with a Directory attribute meant for Type 34/35 custom
         actions - a mismatch that could cause the deferred actions to fail
         at runtime with no useful detail (surfacing only as a generic Burn/
         Windows Installer error). ServiceInstall/ServiceControl are core MSI
         elements purpose-built for this and schedule themselves correctly
         without any manual InstallExecuteSequence authoring. -->

    <Property Id="ARPPRODUCTICON" Value="VisionCoreIcon" />
    <Icon Id="VisionCoreIcon" SourceFile="$(var.SourceDir)\app\VisionCore.WPF.exe" />

  </Package>

  <Fragment>
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLDIR" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="FirewallRules" Directory="TARGETDIR">
      <Component Id="FwRtspComponent" Guid="11111111-1111-1111-1111-111111111101">
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore\Firewall" Name="Rtsp"
          Type="integer" Value="1" KeyPath="yes" />
        <fw:FirewallException Id="FwRtsp" Name="VisionCore RTSP (8554)"
          Port="8554" Protocol="tcp" Scope="any" />
      </Component>
      <Component Id="FwRestApiComponent" Guid="11111111-1111-1111-1111-111111111102">
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore\Firewall" Name="RestApi"
          Type="integer" Value="1" KeyPath="yes" />
        <fw:FirewallException Id="FwRestApi" Name="VisionCore REST API (7880)"
          Port="7880" Protocol="tcp" Scope="localSubnet" />
      </Component>
      <Component Id="FwOnvifComponent" Guid="11111111-1111-1111-1111-111111111103">
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore\Firewall" Name="Onvif"
          Type="integer" Value="1" KeyPath="yes" />
        <fw:FirewallException Id="FwOnvif" Name="VisionCore ONVIF (8080)"
          Port="8080" Protocol="tcp" Scope="any" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="RegistryEntries" Directory="TARGETDIR">
      <Component Id="RegInstallPath" Guid="A3C1D2E4-F5B6-7890-ABCD-EF1234567890">
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="InstallPath"
          Type="string" Value="[INSTALLDIR]" KeyPath="yes" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="Version"
          Type="string" Value="$(var.ProductVersion)" />
        <RegistryValue Root="HKLM" Key="SOFTWARE\VisionCore" Name="ServiceName"
          Type="string" Value="VisionCoreService" />
      </Component>
      <Component Id="RegStartWithWindows" Guid="B4D2E3F5-A6C7-8901-BCDE-F01234567891">
        <RegistryValue Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="VisionCore" Type="string"
          Value="[INSTALLDIR_APP]VisionCore.WPF.exe --minimized" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>

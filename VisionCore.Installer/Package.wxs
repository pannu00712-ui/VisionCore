<?xml version="1.0" encoding="utf-8"?>
<!--
  VisionCore.Installer — Package.wxs
  ════════════════════════════════════
  WiX Toolset v4 (wix4 / HeatWave) package definition.

  Build prerequisites
  ═══════════════════
    dotnet tool install global wix
    wix extension add WixToolset.UI.wixext
    wix extension add WixToolset.Util.wixext
    wix extension add WixToolset.Firewall.wixext

  Build command (from this directory)
  ════════════════════════════════════
    wix build Package.wxs Directories.wxs Features.wxs UI.wxs `
         -ext WixToolset.UI.wixext    `
         -ext WixToolset.Util.wixext  `
         -ext WixToolset.Firewall.wixext `
         -d SourceDir="..\publish"    `
         -o VisionCore-1.0.0-Setup.msi

  The publish/ folder must contain the output of:
    dotnet publish VisionCore.WPF\VisionCore.WPF.csproj     -c Release -r win-x64 self-contained false
    dotnet publish VisionCore.Service\VisionCore.Service.csproj -c Release -r win-x64 self-contained false

  Directory layout expected inside $(var.SourceDir):
    publish\
      app\          — WPF tray application (VisionCore.WPF.exe + deps)
      service\      — Windows Service executable (VisionCore.Service.exe + deps)
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fw="http://wixtoolset.org/schemas/v4/wxs/firewall">

  <Package
    Name="VisionCore"
    Manufacturer="VisionCore"
    Version="1.0.0.0"
    UpgradeCode="E4A7C2D1-8F3B-4E9A-B6C0-12D3E5F7A801"
    Language="1033"
    Codepage="1252"
    InstallerVersion="500"
    Compressed="yes"
    Scope="perMachine">

    <!-- ── Upgrade / downgrade policy ─────────────────────────────────────── -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of VisionCore is already installed."
      Schedule="afterInstallInitialize"
      AllowDowngrades="no"
      AllowSameVersionUpgrades="no" />

    <!-- ── Media / cabinet ────────────────────────────────────────────────── -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- ── Prerequisite: .NET 8 Desktop Runtime ───────────────────────────── -->
    <!--
      We check for the .NET 8 Windows Desktop Runtime host key.
      The bootstrapper (Bundle.wxs) will install it if missing;
      this condition is a fallback guard for MSI-only installs.
    -->
    <Launch
      Condition="DOTNET8_DESKTOP_INSTALLED"
      Message="VisionCore requires .NET 8 Windows Desktop Runtime.  Please install it from https://dotnet.microsoft.com/download/dotnet/8.0 and run Setup again." />

    <!-- ── Property: detect .NET 8 Desktop Runtime (x64 or x86) ─────────── -->
    <Property Id="DOTNET8_DESKTOP_INSTALLED">
      <RegistrySearch
        Id="SearchDotNet8Desktop64"
        Root="HKLM"
        Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
        Name="8.0.0"
        Type="raw" />
      <RegistrySearch
        Id="SearchDotNet8Desktop86"
        Root="HKLM"
        Key="SOFTWARE\dotnet\Setup\InstalledVersions\x86\sharedfx\Microsoft.WindowsDesktop.App"
        Name="8.0.0"
        Type="raw" />
    </Property>

    <!-- ── Property: detect existing service install path (for upgrades) ──── -->
    <Property Id="INSTALLDIR_FROM_REGISTRY">
      <RegistrySearch
        Id="SearchInstallDir"
        Root="HKLM"
        Key="SOFTWARE\VisionCore"
        Name="InstallPath"
        Type="raw" />
    </Property>

    <!-- ── Runtime properties ─────────────────────────────────────────────── -->
    <Property Id="WIXUI_INSTALLDIR"       Value="INSTALLDIR" />
    <Property Id="INSTALL_SERVICE"        Value="1" />   <!-- checked by default -->
    <Property Id="AUTOSTART_SERVICE"      Value="1" />
    <Property Id="ADD_FIREWALL_RULE"      Value="1" />
    <Property Id="CREATE_DESKTOP_SHORTCUT" Value="1" />
    <Property Id="CREATE_STARTMENU_SHORTCUT" Value="1" />

    <!-- Preserve install dir across upgrades -->
    <SetProperty
      Id="INSTALLDIR"
      Value="[INSTALLDIR_FROM_REGISTRY]"
      After="AppSearch"
      Sequence="execute"
      Condition="INSTALLDIR_FROM_REGISTRY" />

    <!-- ── Standard Windows Installer sequences ───────────────────────────── -->
    <InstallExecuteSequence>
      <!-- Stop service before files are removed / replaced -->
      <Custom Action="StopVisionCoreService"   Before="InstallFiles"   Condition="(NOT UPGRADINGPRODUCTCODE) AND (REMOVE~=&quot;ALL&quot;)" />
      <Custom Action="StopVisionCoreService"   Before="InstallFiles"   Condition="UPGRADINGPRODUCTCODE" />

      <!-- Install / start service after files land -->
      <Custom Action="InstallVisionCoreService"  After="InstallFiles"   Condition="INSTALL_SERVICE AND (NOT REMOVE)" />
      <Custom Action="StartVisionCoreService"    After="InstallVisionCoreService" Condition="AUTOSTART_SERVICE AND INSTALL_SERVICE AND (NOT REMOVE)" />

      <!-- Remove service on uninstall -->
      <Custom Action="RemoveVisionCoreService"  Before="RemoveFiles"   Condition="REMOVE~=&quot;ALL&quot; AND (NOT UPGRADINGPRODUCTCODE)" />
    </InstallExecuteSequence>

    <!-- ── Custom actions ─────────────────────────────────────────────────── -->

    <!-- sc.exe install -->
    <CustomAction
      Id="InstallVisionCoreService"
      Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe create VisionCoreService binPath= &quot;[INSTALLDIR_SERVICE]VisionCore.Service.exe&quot; start= auto DisplayName= &quot;VisionCore Streaming Engine&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- sc.exe description -->
    <CustomAction
      Id="SetServiceDescription"
      Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe description VisionCoreService &quot;Manages RTSP / ONVIF camera streams, motion detection, and the REST API for the VisionCore surveillance platform.&quot;"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- sc.exe start -->
    <CustomAction
      Id="StartVisionCoreService"
      Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe start VisionCoreService"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- sc.exe stop -->
    <CustomAction
      Id="StopVisionCoreService"
      Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe stop VisionCoreService"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- sc.exe delete -->
    <CustomAction
      Id="RemoveVisionCoreService"
      Directory="INSTALLDIR_SERVICE"
      ExeCommand="[SystemFolder]sc.exe delete VisionCoreService"
      Execute="deferred"
      Impersonate="no"
      Return="ignore" />

    <!-- ── Firewall: RTSP 8554, REST API 7880, ONVIF 8080 ─────────────────── -->
    <!--
      WiX v4 syntax: extension elements like fw:FirewallException must be
      nested inside a <Component> (they need a KeyPath / install context),
      not placed directly under <Package> as in some v3-style examples.
      Each firewall rule gets its own Component referenced by RegistryEntries.
    -->
    <ComponentGroup Id="FirewallRules" Directory="TARGETDIR">
      <Component Id="FwRtspComponent" Guid="11111111-1111-1111-1111-111111111101"
                 Condition="ADD_FIREWALL_RULE">
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore\Firewall"
          Name="Rtsp"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <fw:FirewallException
          Id="FwRtsp"
          Name="VisionCore RTSP (8554)"
          Port="8554"
          Protocol="tcp"
          Scope="any" />
      </Component>

      <Component Id="FwRestApiComponent" Guid="11111111-1111-1111-1111-111111111102"
                 Condition="ADD_FIREWALL_RULE">
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore\Firewall"
          Name="RestApi"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <fw:FirewallException
          Id="FwRestApi"
          Name="VisionCore REST API (7880)"
          Port="7880"
          Protocol="tcp"
          Scope="localSubnet" />
      </Component>

      <Component Id="FwOnvifComponent" Guid="11111111-1111-1111-1111-111111111103"
                 Condition="ADD_FIREWALL_RULE">
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore\Firewall"
          Name="Onvif"
          Type="integer"
          Value="1"
          KeyPath="yes" />
        <fw:FirewallException
          Id="FwOnvif"
          Name="VisionCore ONVIF (8080)"
          Port="8080"
          Protocol="tcp"
          Scope="any" />
      </Component>
    </ComponentGroup>

    <!-- ── Registry ────────────────────────────────────────────────────────── -->
    <ComponentGroup Id="RegistryEntries" Directory="TARGETDIR">
      <Component Id="RegInstallPath" Guid="A3C1D2E4-F5B6-7890-ABCD-EF1234567890">
        <!-- Record install path for upgrade detection -->
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore"
          Name="InstallPath"
          Type="string"
          Value="[INSTALLDIR]"
          KeyPath="yes" />
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore"
          Name="Version"
          Type="string"
          Value="1.0.0" />
        <RegistryValue
          Root="HKLM"
          Key="SOFTWARE\VisionCore"
          Name="ServiceName"
          Type="string"
          Value="VisionCoreService" />
      </Component>

      <!-- Start with Windows (current user) — mirrors SettingsViewModel.StartWithWindows -->
      <Component Id="RegStartWithWindows" Guid="B4D2E3F5-A6C7-8901-BCDE-F01234567891"
                 Condition="CREATE_DESKTOP_SHORTCUT">
        <RegistryValue
          Root="HKCU"
          Key="SOFTWARE\Microsoft\Windows\CurrentVersion\Run"
          Name="VisionCore"
          Type="string"
          Value="[INSTALLDIR_APP]VisionCore.WPF.exe --minimized"
          KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <!-- ── Uninstall shortcut in Programs & Features ───────────────────────── -->
    <Property Id="ARPPRODUCTICON" Value="VisionCoreIcon" />
    <Property Id="ARPHELPLINK"    Value="https://github.com/your-org/visioncore" />
    <Property Id="ARPURLINFOABOUT" Value="https://github.com/your-org/visioncore" />
    <Icon Id="VisionCoreIcon" SourceFile="$(var.SourceDir)\app\VisionCore.WPF.exe" />

  </Package>
</Wix>

<?xml version="1.0" encoding="utf-8"?>
<!--
  VisionCore.Installer — Bundle.wxs
  ════════════════════════════════════
  WiX 4 Burn bootstrapper.

  What it does
  ════════════
  1. Checks whether .NET 8 Windows Desktop Runtime is already installed.
  2. If not, downloads and installs it silently from Microsoft's CDN.
  3. Installs (or upgrades) the VisionCore MSI built from the other .wxs files.

  Build command (run after building the MSI)
  ════════════════════════════════════════════
    wix build Bundle.wxs                          `
         -ext WixToolset.Bootstrapper.wixext      `
         -ext WixToolset.Bal.wixext               `
         -d MsiPath=".\VisionCore-1.0.0-Setup.msi" `
         -o VisionCore-1.0.0-Setup.exe

  Requires: WixToolset.Bal.wixext  (Managed Bootstrapper Application)

  Silent install
  ═══════════════
    VisionCore-1.0.0-Setup.exe /quiet
    VisionCore-1.0.0-Setup.exe /quiet INSTALL_SERVICE=0

  Silent uninstall
  ═════════════════
    VisionCore-1.0.0-Setup.exe /quiet /uninstall
-->

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:bal="http://wixtoolset.org/schemas/v4/wxs/bal"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <Bundle
    Name="VisionCore"
    Version="1.0.0.0"
    Manufacturer="VisionCore"
    UpgradeCode="F5B8D3C2-9E4A-4F7B-A0D1-23E4F6A8B902"
    IconSourceFile="Assets\setup-icon.ico"
    About="VisionCore Camera Streaming Platform"
    HelpUrl="https://github.com/your-org/visioncore"
    DisableModify="button">

    <!-- ── Bootstrapper Application UI ───────────────────────────────────── -->
    <!--
      WixStandardBootstrapperApplication renders a simple themed setup window.
      Replace with a custom MBA (WpfBootstrapperApplication) for full custom UI.
    -->
    <bal:WixStandardBootstrapperApplication
      LicenseFile="License.rtf"
      Theme="hyperlinkLicense"
      SuppressOptionsUI="no"
      ShowVersion="yes" />

    <!-- ── Variables exposed to the MSI ──────────────────────────────────── -->
    <Variable Name="INSTALL_SERVICE"           Type="numeric" Value="1" bal:Overridable="yes" />
    <Variable Name="AUTOSTART_SERVICE"         Type="numeric" Value="1" bal:Overridable="yes" />
    <Variable Name="ADD_FIREWALL_RULE"         Type="numeric" Value="1" bal:Overridable="yes" />
    <Variable Name="CREATE_DESKTOP_SHORTCUT"   Type="numeric" Value="1" bal:Overridable="yes" />
    <Variable Name="CREATE_STARTMENU_SHORTCUT" Type="numeric" Value="1" bal:Overridable="yes" />

    <!-- ── Prerequisite detection ────────────────────────────────────────── -->
    <!--
      The bundle looks for the .NET 8.0 Windows Desktop Runtime host key.
      If the registry value is absent the DotNet8Package chain entry runs.
    -->
    <util:RegistrySearch
      Id="SearchDotNet8Desktop"
      Root="HKLM"
      Key="SOFTWARE\dotnet\Setup\InstalledVersions\x64\sharedfx\Microsoft.WindowsDesktop.App"
      Value="8.0.0"
      Variable="DotNet8DesktopInstalled"
      Result="exists" />

    <!-- ── Package chain ─────────────────────────────────────────────────── -->
    <Chain DisableRollback="no">

      <!-- 1. .NET 8 Windows Desktop Runtime — x64 -->
      <ExePackage
        Id="DotNet8Package_x64"
        Name=".NET 8 Windows Desktop Runtime (x64)"
        SourceFile="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x64.exe"
        DownloadUrl="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x64.exe"
        InstallCommand="/install /quiet /norestart"
        RepairCommand="/repair /quiet /norestart"
        UninstallCommand="/uninstall /quiet /norestart"
        DetectCondition="DotNet8DesktopInstalled"
        Compressed="no"
        PerMachine="yes"
        Vital="yes"
        Condition="NOT DotNet8DesktopInstalled AND (VersionNT64)" />

      <!-- 1b. .NET 8 Windows Desktop Runtime — x86 -->
      <ExePackage
        Id="DotNet8Package_x86"
        Name=".NET 8 Windows Desktop Runtime (x86)"
        SourceFile="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x86.exe"
        DownloadUrl="https://aka.ms/dotnet/8.0/windowsdesktop-runtime-win-x86.exe"
        InstallCommand="/install /quiet /norestart"
        RepairCommand="/repair /quiet /norestart"
        UninstallCommand="/uninstall /quiet /norestart"
        DetectCondition="DotNet8DesktopInstalled"
        Compressed="no"
        PerMachine="yes"
        Vital="yes"
        Condition="NOT DotNet8DesktopInstalled AND NOT (VersionNT64)" />

      <!-- 2. VisionCore MSI -->
      <MsiPackage
        Id="VisionCoreMsi"
        SourceFile="$(var.MsiPath)"
        EnableFeatureSelection="no"
        ForcePerMachine="yes"
        Vital="yes">

        <!-- Pass bootstrapper variables into the MSI as properties -->
        <MsiProperty Name="INSTALL_SERVICE"           Value="[INSTALL_SERVICE]" />
        <MsiProperty Name="AUTOSTART_SERVICE"         Value="[AUTOSTART_SERVICE]" />
        <MsiProperty Name="ADD_FIREWALL_RULE"         Value="[ADD_FIREWALL_RULE]" />
        <MsiProperty Name="CREATE_DESKTOP_SHORTCUT"   Value="[CREATE_DESKTOP_SHORTCUT]" />
        <MsiProperty Name="CREATE_STARTMENU_SHORTCUT" Value="[CREATE_STARTMENU_SHORTCUT]" />

      </MsiPackage>

    </Chain>

  </Bundle>

</Wix>

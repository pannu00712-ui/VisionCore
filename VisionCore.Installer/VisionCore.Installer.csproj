<Project Sdk="WixToolset.Sdk/4.0.5">

  <PropertyGroup>
    <ProductName>VisionCore</ProductName>
    <ProductVersion Condition="'$(ProductVersion)'==''">1.0.0</ProductVersion>
    <Manufacturer>VisionCore</Manufacturer>
    <OutputName Condition="'$(OutputName)'==''">VisionCore-$(ProductVersion)-Setup-x64</OutputName>
    <SourceDir Condition="'$(SourceDir)'==''">$(MSBuildThisFileDirectory)..\publish</SourceDir>
    <InstallerPlatform Condition="'$(InstallerPlatform)'==''">x64</InstallerPlatform>
    <Nullable>enable</Nullable>
    <DefineConstants>SourceDir=$(SourceDir)</DefineConstants>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultItems>false</EnableDefaultItems>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext"       Version="4.0.5"/>
    <PackageReference Include="WixToolset.Util.wixext"     Version="4.0.5"/>
    <PackageReference Include="WixToolset.Firewall.wixext" Version="4.0.5"/>
  </ItemGroup>

  <ItemGroup>
    <Compile Include="Package.wxs"/>
    <Compile Include="Directories.wxs"/>
    <Compile Include="Features.wxs"/>
    <Compile Include="UI.wxs"/>
  </ItemGroup>

  <ItemGroup>
    <Content Include="License.rtf"           CopyToOutputDirectory="PreserveNewest"/>
    <Content Include="Assets\setup-icon.ico" CopyToOutputDirectory="PreserveNewest"/>
  </ItemGroup>

  <Target Name="CheckPublishOutputs" BeforeTargets="Build">
    <Warning Condition="!Exists('$(SourceDir)\app\VisionCore.WPF.exe')"
             Text="WPF publish output not found at $(SourceDir)\app\. Run dotnet publish first."/>
    <Warning Condition="!Exists('$(SourceDir)\service\VisionCore.Service.exe')"
             Text="Service publish output not found at $(SourceDir)\service\. Run dotnet publish first."/>
  </Target>

</Project>

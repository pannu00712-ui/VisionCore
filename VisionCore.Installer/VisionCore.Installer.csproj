<Project Sdk="WixToolset.Sdk/4.0.5">

  <!--
    ═══════════════════════════════════════════════════════════════════════
    VisionCore Installer — WiX 4 project
    Produces:
      VisionCore-1.0.0-Setup.msi   (MSI — enterprise / GPO)
      VisionCore-1.0.0-Setup.exe   (Burn bootstrapper — .NET 8 prereq + MSI)

    Prerequisites (run once):
      dotnet tool install global wix
      wix extension add WixToolset.UI.wixext
      wix extension add WixToolset.Util.wixext
      wix extension add WixToolset.Firewall.wixext
      wix extension add WixToolset.Bal.wixext

    Build (from solution root):
      dotnet publish VisionCore.WPF\VisionCore.WPF.csproj -c Release -r win-x64 ^
             self-contained false -o publish\app
      dotnet publish VisionCore.Service\VisionCore.Service.csproj -c Release -r win-x64 ^
             self-contained false -o publish\service
      dotnet build VisionCore.Installer\VisionCore.Installer.csproj -c Release
    ═══════════════════════════════════════════════════════════════════════
  -->

  <PropertyGroup>
    <ProductName>VisionCore</ProductName>
    <ProductVersion>1.0.0</ProductVersion>
    <Manufacturer>VisionCore</Manufacturer>
    <OutputName Condition="'$(OutputName)'==''">VisionCore-$(ProductVersion)-Setup-x64</OutputName>
    <!-- Source directory where dotnet publish output is placed -->
    <SourceDir Condition="'$(SourceDir)'==''">$(MSBuildThisFileDirectory)..\publish\x64</SourceDir>
    <!-- Platform: x64 (default) or x86 -->
    <InstallerPlatform Condition="'$(InstallerPlatform)'==''">x64</InstallerPlatform>
    <Nullable>enable</Nullable>
    <!--
      Bridge the MSBuild property SourceDir into a WiX preprocessor
      variable. Without this, $(var.SourceDir) in the .wxs files is
      undefined — WiX preprocessor variables are NOT auto-populated
      from MSBuild properties of the same name.

      NOTE: InstallerPlatform is NOT added here — WixToolset.Sdk already
      auto-promotes it to a WiX preprocessor variable by convention since
      it's declared as an MSBuild property above. Adding it again here
      causes WIX0288 (variable already declared).
    -->
    <DefineConstants>SourceDir=$(SourceDir)</DefineConstants>
  </PropertyGroup>

  <!-- Platform-specific MSI settings -->
  <PropertyGroup Condition="'$(InstallerPlatform)'=='x64'">
    <WixInstallerPlatform>x64</WixInstallerPlatform>
    <WixArchitecture>x64</WixArchitecture>
  </PropertyGroup>
  <PropertyGroup Condition="'$(InstallerPlatform)'=='x86'">
    <WixInstallerPlatform>x86</WixInstallerPlatform>
    <WixArchitecture>x86</WixArchitecture>
  </PropertyGroup>

  <!-- ── WiX extensions ─────────────────────────────────────────────────── -->
  <ItemGroup>
    <PackageReference Include="WixToolset.UI.wixext"       Version="4.0.5"/>
    <PackageReference Include="WixToolset.Util.wixext"     Version="4.0.5"/>
    <PackageReference Include="WixToolset.Firewall.wixext" Version="4.0.5"/>
    <PackageReference Include="WixToolset.Bal.wixext"      Version="4.0.5"/>
    <!--
      HeatWave Community Edition (free) — provides fg:HarvestFolder for
      recursively harvesting the dotnet publish output directories.
      The native, namespace-less <Files> wildcard element does not exist
      until WiX v5; on WiX 4.0.5 HarvestFolder is the supported approach.
    -->
    <PackageReference Include="FireGiant.HeatWave.BuildTools.wixext" Version="4.0.1"/>
  </ItemGroup>

  <!-- ── WiX source files (MSI only — Bundle.wxs is built separately) ────── -->
  <!--
    WixToolset.Sdk auto-includes every .wxs file in the project folder by
    default (EnableDefaultCompileItems=true), regardless of the explicit
    <Compile Include> entries below. Bundle.wxs lives in this same folder
    (so VisionCore.Bundle.csproj can find it too) but must NOT be compiled
    into this MSI project — it defines a separate root-level <Bundle>
    output that cannot coexist with <Package> in one compile. Explicitly
    removing it here prevents it from being silently auto-included.
  -->
  <ItemGroup>
    <Compile Remove="Bundle.wxs"/>
  </ItemGroup>
  <ItemGroup>
    <Compile Include="Package.wxs"/>
    <Compile Include="Directories.wxs"/>
    <Compile Include="Features.wxs"/>
    <Compile Include="UI.wxs"/>
  </ItemGroup>

  <!-- ── Embedded assets ────────────────────────────────────────────────── -->
  <ItemGroup>
    <Content Include="License.rtf"          CopyToOutputDirectory="PreserveNewest"/>
    <Content Include="Assets\setup-icon.ico" CopyToOutputDirectory="PreserveNewest"/>
  </ItemGroup>

  <!-- ── Pre-build: verify publish outputs exist ────────────────────────── -->
  <Target Name="CheckPublishOutputs" BeforeTargets="Build">
    <Warning Condition="!Exists('$(SourceDir)\app\VisionCore.WPF.exe')"
             Text="WPF publish output not found at $(SourceDir)\app\. Run 'dotnet publish' first."/>
    <Warning Condition="!Exists('$(SourceDir)\service\VisionCore.Service.exe')"
             Text="Service publish output not found at $(SourceDir)\service\. Run 'dotnet publish' first."/>
  </Target>

</Project>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="VisionCore">
        <Directory Id="APPFOLDER" Name="app" />
        <Directory Id="SERVICEFOLDER" Name="service" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="STARTMENU_VISIONCORE" Name="VisionCore" />
    </StandardDirectory>

    <StandardDirectory Id="DesktopFolder" />
  </Fragment>

  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="APPFOLDER">
      <Component Id="AppFilesComponent" Guid="a1b2c3d4-e5f6-4789-abcd-ef0123456789">
        <File Id="AppMainExe"
              Source="$(var.SourceDir)\app\VisionCore.WPF.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="AppDirComponent" Guid="b2c3d4e5-f6a7-4890-bcde-f01234567890">
        <CreateFolder Directory="APPFOLDER" />
        <RemoveFolder Id="RemoveAppFolder" Directory="APPFOLDER" On="uninstall" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ServiceComponents" Directory="SERVICEFOLDER">
      <Component Id="ServiceMainExe" Guid="c3d4e5f6-a7b8-4901-cdef-012345678901">
        <File Id="ServiceExe"
              Source="$(var.SourceDir)\service\VisionCore.Service.exe"
              KeyPath="yes" />
      </Component>
      <Component Id="ServiceDirComponent" Guid="d4e5f6a7-b8c9-4012-defa-123456789012">
        <CreateFolder Directory="SERVICEFOLDER" />
        <RemoveFolder Id="RemoveServiceFolder" Directory="SERVICEFOLDER" On="uninstall" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ShortcutComponents" Directory="STARTMENU_VISIONCORE">
      <Component Id="StartMenuShortcutComponent" Guid="e5f6a7b8-c9d0-4123-efab-234567890123">
        <Shortcut Id="StartMenuShortcut"
                  Name="VisionCore"
                  Description="VisionCore Application"
                  Target="[APPFOLDER]VisionCore.WPF.exe"
                  WorkingDirectory="APPFOLDER" />
        <RemoveFolder Id="RemoveStartMenuFolder"
                      Directory="STARTMENU_VISIONCORE"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\VisionCore"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <Component Id="DesktopShortcutComponent" Guid="f6a7b8c9-d0e1-4234-fabc-345678901234" Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcut"
                  Name="VisionCore"
                  Description="VisionCore Application"
                  Target="[APPFOLDER]VisionCore.WPF.exe"
                  WorkingDirectory="APPFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\VisionCore"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>

<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- Directory structure -->
  <Fragment>
    <Directory Id="TARGETDIR" Name="SourceDir">

      <!-- Program Files installation directory -->
      <Directory Id="ProgramFiles6432Folder">
        <Directory Id="INSTALLFOLDER" Name="VisionCore">
          <Directory Id="APPFOLDER" Name="app" />
          <Directory Id="SERVICEFOLDER" Name="service" />
        </Directory>
      </Directory>

      <!-- Start Menu shortcut directory (user profile) -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="STARTMENU_VISIONCORE" Name="VisionCore" />
      </Directory>

      <!-- Desktop shortcut directory -->
      <Directory Id="DesktopFolder" Name="Desktop" />

    </Directory>
  </Fragment>

  <!-- App files component group -->
  <Fragment>
    <ComponentGroup Id="AppComponents" Directory="APPFOLDER">
      <Component Id="AppFilesComponent" Guid="*">
        <Files Include="$(var.SourceDir)\app\**" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Service files component group -->
  <Fragment>
    <ComponentGroup Id="ServiceComponents" Directory="SERVICEFOLDER">
      <Component Id="ServiceFilesComponent" Guid="*">
        <Files Include="$(var.SourceDir)\service\**" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- Start Menu shortcut component -->
  <Fragment>
    <ComponentGroup Id="ShortcutComponents" Directory="STARTMENU_VISIONCORE">
      <Component Id="StartMenuShortcutComponent" Guid="*">
        <Shortcut Id="StartMenuShortcut"
                  Name="VisionCore"
                  Description="VisionCore Application"
                  Target="[APPFOLDER]VisionCore.WPF.exe"
                  WorkingDirectory="APPFOLDER" />
        <!-- REQUIRED: RemoveFolder for user-profile Start Menu dir (fixes ICE64) -->
        <RemoveFolder Id="RemoveStartMenuFolder"
                      Directory="STARTMENU_VISIONCORE"
                      On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\VisionCore"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>

      <!-- Desktop shortcut component -->
      <Component Id="DesktopShortcutComponent" Guid="*" Directory="DesktopFolder">
        <Shortcut Id="DesktopShortcut"
                  Name="VisionCore"
                  Description="VisionCore Application"
                  Target="[APPFOLDER]VisionCore.WPF.exe"
                  WorkingDirectory="APPFOLDER" />
        <RegistryValue Root="HKCU"
                       Key="Software\VisionCore"
                       Name="DesktopShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>

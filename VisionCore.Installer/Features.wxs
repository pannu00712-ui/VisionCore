<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>
    <Feature Id="ProductFeature" Title="VisionCore"
      Description="The core VisionCore platform."
      Level="1" ConfigurableDirectory="INSTALLDIR"
      Display="expand" InstallDefault="local" AllowAbsent="no">

      <Feature Id="AppFeature" Title="VisionCore Desktop App"
        Description="The WPF tray application."
        Level="1" Display="expand" InstallDefault="local" AllowAbsent="no">
        <ComponentGroupRef Id="AppFiles" />
        <ComponentGroupRef Id="RegistryEntries" />
      </Feature>

      <Feature Id="ServiceFeature" Title="Background Windows Service"
        Description="Runs the RTSP/ONVIF streaming engine as a Windows Service."
        Level="1" Display="expand" InstallDefault="local" AllowAbsent="yes">
        <Level Value="0" Condition="NOT INSTALL_SERVICE" />
        <ComponentGroupRef Id="ServiceFiles" />
        <ComponentGroupRef Id="DataDir" />
        <ComponentGroupRef Id="FirewallRules" />
      </Feature>

      <Feature Id="ShortcutsFeature" Title="Shortcuts"
        Description="Create desktop and Start Menu shortcuts."
        Level="1" Display="expand" InstallDefault="local" AllowAbsent="yes">
        <Level Value="0" Condition="NOT CREATE_DESKTOP_SHORTCUT AND NOT CREATE_STARTMENU_SHORTCUT" />
      </Feature>

    </Feature>
  </Fragment>

</Wix>

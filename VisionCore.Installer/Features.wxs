<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Fragment>
    <Feature
      Id="ProductFeature"
      Title="VisionCore"
      Description="The core VisionCore platform."
      Level="1"
      ConfigurableDirectory="INSTALLDIR"
      Display="expand"
      InstallDefault="local"
      AllowAbsent="no">

      <Feature
        Id="AppFeature"
        Title="VisionCore Desktop App"
        Description="The WPF tray application."
        Level="1"
        Display="expand"
        InstallDefault="local"
        AllowAbsent="no">
        <ComponentGroupRef Id="AppFiles" />
        <ComponentGroupRef Id="RegistryEntries" />
        <ComponentGroupRef Id="ShortcutComponents" />
        <ComponentGroupRef Id="FirewallRules" />
      </Feature>

      <Feature
        Id="ServiceFeature"
        Title="Background Windows Service"
        Description="Runs the RTSP/ONVIF streaming engine as a Windows Service."
        Level="1"
        Display="expand"
        InstallDefault="local"
        AllowAbsent="yes">
        <ComponentGroupRef Id="ServiceFiles" />
        <ComponentGroupRef Id="DataDir" />
      </Feature>

    </Feature>
  </Fragment>

</Wix>

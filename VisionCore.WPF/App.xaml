<Application
    x:Class="VisionCore.WPF.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    ShutdownMode="OnExplicitShutdown">

    <!--
        ShutdownMode="OnExplicitShutdown" — because we manage the tray icon
        ourselves and call Application.Current.Shutdown() from the exit menu item.
        WPF must NOT auto-shutdown when MainWindow is hidden to tray.
    -->

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>

                <!--
                    Theme dictionary — placeholder slot.
                    App.xaml.cs replaces this at runtime via ApplyTheme().
                    Starting with DarkTheme so the window that appears before
                    settings load uses the correct palette.
                -->
                <ResourceDictionary
                    Source="pack://application:,,,/VisionCore.WPF;component/Themes/DarkTheme.xaml"/>

            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

</Application>

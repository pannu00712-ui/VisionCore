<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════════════
         VisionCore — Light Theme
         Palette: crisp off-white surface, slate text, teal accent, amber warnings
    ═══════════════════════════════════════════════════════════════════════════ -->

    <!-- ── Colour primitives ───────────────────────────────────────────────── -->
    <Color x:Key="Col.Background">#F5F6F8</Color>
    <Color x:Key="Col.Surface">#FFFFFF</Color>
    <Color x:Key="Col.SurfaceAlt">#EEF0F3</Color>
    <Color x:Key="Col.Border">#D4D8DE</Color>
    <Color x:Key="Col.BorderFocus">#2AADAD</Color>

    <Color x:Key="Col.Text.Primary">#1A1E26</Color>
    <Color x:Key="Col.Text.Secondary">#5A6272</Color>
    <Color x:Key="Col.Text.Disabled">#A8AFBB</Color>
    <Color x:Key="Col.Text.OnAccent">#FFFFFF</Color>

    <Color x:Key="Col.Accent">#1E9E9E</Color>
    <Color x:Key="Col.AccentHover">#17888A</Color>
    <Color x:Key="Col.AccentLight">#E0F5F5</Color>

    <Color x:Key="Col.Danger">#D93025</Color>
    <Color x:Key="Col.DangerLight">#FDECEA</Color>
    <Color x:Key="Col.Warning">#E07B00</Color>
    <Color x:Key="Col.WarningLight">#FEF3E0</Color>
    <Color x:Key="Col.Success">#1E8C5A</Color>
    <Color x:Key="Col.SuccessLight">#E3F4EC</Color>

    <Color x:Key="Col.Overlay">#22000000</Color>

    <!-- ── Solid brushes ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="Brush.Background"   Color="{StaticResource Col.Background}"/>
    <SolidColorBrush x:Key="Brush.Surface"      Color="{StaticResource Col.Surface}"/>
    <SolidColorBrush x:Key="Brush.SurfaceAlt"   Color="{StaticResource Col.SurfaceAlt}"/>
    <SolidColorBrush x:Key="Brush.Border"       Color="{StaticResource Col.Border}"/>
    <SolidColorBrush x:Key="Brush.BorderFocus"  Color="{StaticResource Col.BorderFocus}"/>

    <SolidColorBrush x:Key="Brush.Text.Primary"   Color="{StaticResource Col.Text.Primary}"/>
    <SolidColorBrush x:Key="Brush.Text.Secondary" Color="{StaticResource Col.Text.Secondary}"/>
    <SolidColorBrush x:Key="Brush.Text.Disabled"  Color="{StaticResource Col.Text.Disabled}"/>
    <SolidColorBrush x:Key="Brush.Text.OnAccent"  Color="{StaticResource Col.Text.OnAccent}"/>

    <SolidColorBrush x:Key="Brush.Accent"       Color="{StaticResource Col.Accent}"/>
    <SolidColorBrush x:Key="Brush.AccentHover"  Color="{StaticResource Col.AccentHover}"/>
    <SolidColorBrush x:Key="Brush.AccentLight"  Color="{StaticResource Col.AccentLight}"/>

    <SolidColorBrush x:Key="Brush.Danger"       Color="{StaticResource Col.Danger}"/>
    <SolidColorBrush x:Key="Brush.DangerLight"  Color="{StaticResource Col.DangerLight}"/>
    <SolidColorBrush x:Key="Brush.Warning"      Color="{StaticResource Col.Warning}"/>
    <SolidColorBrush x:Key="Brush.WarningLight" Color="{StaticResource Col.WarningLight}"/>
    <SolidColorBrush x:Key="Brush.Success"      Color="{StaticResource Col.Success}"/>
    <SolidColorBrush x:Key="Brush.SuccessLight" Color="{StaticResource Col.SuccessLight}"/>
    <SolidColorBrush x:Key="Brush.Overlay"      Color="{StaticResource Col.Overlay}"/>

    <!-- ── Gradient brushes ───────────────────────────────────────────────── -->
    <LinearGradientBrush x:Key="Brush.Accent.Gradient" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource Col.Accent}"      Offset="0"/>
        <GradientStop Color="{StaticResource Col.AccentHover}" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.Surface.Shadow" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#08000000" Offset="0"/>
        <GradientStop Color="#00000000" Offset="1"/>
    </LinearGradientBrush>

    <!-- ── Typography ─────────────────────────────────────────────────────── -->
    <!-- Display / heading: Inter (or Segoe UI as fallback) -->
    <FontFamily x:Key="Font.Display">Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Body">Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="Font.Mono">Consolas, Cascadia Code, monospace</FontFamily>

    <system:Double x:Key="FontSize.XS"  xmlns:system="clr-namespace:System;assembly=mscorlib">10</system:Double>
    <system:Double x:Key="FontSize.SM"  xmlns:system="clr-namespace:System;assembly=mscorlib">11</system:Double>
    <system:Double x:Key="FontSize.MD"  xmlns:system="clr-namespace:System;assembly=mscorlib">13</system:Double>
    <system:Double x:Key="FontSize.LG"  xmlns:system="clr-namespace:System;assembly=mscorlib">15</system:Double>
    <system:Double x:Key="FontSize.XL"  xmlns:system="clr-namespace:System;assembly=mscorlib">18</system:Double>
    <system:Double x:Key="FontSize.2XL" xmlns:system="clr-namespace:System;assembly=mscorlib">22</system:Double>
    <system:Double x:Key="FontSize.3XL" xmlns:system="clr-namespace:System;assembly=mscorlib">28</system:Double>

    <!-- ── Corner radii ───────────────────────────────────────────────────── -->
    <CornerRadius x:Key="Radius.SM">4</CornerRadius>
    <CornerRadius x:Key="Radius.MD">6</CornerRadius>
    <CornerRadius x:Key="Radius.LG">10</CornerRadius>
    <CornerRadius x:Key="Radius.XL">14</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">100</CornerRadius>

    <!-- ── Spacing tokens ─────────────────────────────────────────────────── -->
    <Thickness x:Key="Spacing.Input">10,7,10,7</Thickness>
    <Thickness x:Key="Spacing.ButtonPad">14,7,14,7</Thickness>
    <Thickness x:Key="Spacing.Card">16</Thickness>
    <Thickness x:Key="Spacing.SectionGap">0,0,0,20</Thickness>

    <!-- ─────────────────────────────────────────────────────────────────────
         BASE CONTROL STYLES
    ───────────────────────────────────────────────────────────────────────── -->

    <!-- Window background -->
    <Style x:Key="WindowBase" TargetType="Window">
        <Setter Property="Background"    Value="{StaticResource Brush.Background}"/>
        <Setter Property="Foreground"    Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"    Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"      Value="{StaticResource FontSize.MD}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- ── TextBlock ──────────────────────────────────────────────────────── -->
    <Style TargetType="TextBlock">
        <Setter Property="Foreground"        Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily"        Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"          Value="{StaticResource FontSize.MD}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="Text.Secondary" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.SM}"/>
    </Style>

    <Style x:Key="Text.Label" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize.SM}"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="Margin"       Value="0,0,0,4"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
    </Style>

    <Style x:Key="Text.Heading" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.XL}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="Text.SectionHeader" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource Brush.Accent}"/>
        <Setter Property="FontSize"     Value="{StaticResource FontSize.XS}"/>
        <Setter Property="FontWeight"   Value="Bold"/>
        <Setter Property="Margin"       Value="0,0,0,10"/>
    </Style>

    <Style x:Key="Text.Mono" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource Font.Mono}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.SM}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
    </Style>

    <Style x:Key="Text.Error" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.SM}"/>
    </Style>

    <!-- ── TextBox ────────────────────────────────────────────────────────── -->
    <Style TargetType="TextBox">
        <Setter Property="Background"           Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground"           Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush"          Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness"      Value="1"/>
        <Setter Property="Padding"              Value="{StaticResource Spacing.Input}"/>
        <Setter Property="FontFamily"           Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"             Value="{StaticResource FontSize.MD}"/>
        <Setter Property="CaretBrush"           Value="{StaticResource Brush.Accent}"/>
        <Setter Property="SelectionBrush"       Value="{StaticResource Brush.AccentLight}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.SM}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderFocus}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"  Value="{StaticResource Brush.SurfaceAlt}"/>
                            <Setter Property="Foreground"  Value="{StaticResource Brush.Text.Disabled}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── PasswordBox ────────────────────────────────────────────────────── -->
    <Style TargetType="PasswordBox">
        <Setter Property="Background"       Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground"       Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="{StaticResource Spacing.Input}"/>
        <Setter Property="FontFamily"       Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"         Value="{StaticResource FontSize.MD}"/>
        <Setter Property="CaretBrush"       Value="{StaticResource Brush.Accent}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.SM}"
                            SnapsToDevicePixels="True">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="{TemplateBinding Padding}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsFocused" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.BorderFocus}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── ComboBox ───────────────────────────────────────────────────────── -->
    <Style TargetType="ComboBox">
        <Setter Property="Background"      Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="{StaticResource Spacing.Input}"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="Height"          Value="34"/>
    </Style>

    <!-- ── CheckBox ───────────────────────────────────────────────────────── -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="FontFamily" Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSize.MD}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ── Slider ─────────────────────────────────────────────────────────── -->
    <Style TargetType="Slider">
        <Setter Property="Foreground"  Value="{StaticResource Brush.Accent}"/>
    </Style>

    <!-- ── ProgressBar ────────────────────────────────────────────────────── -->
    <Style TargetType="ProgressBar">
        <Setter Property="Background"  Value="{StaticResource Brush.SurfaceAlt}"/>
        <Setter Property="Foreground"  Value="{StaticResource Brush.Accent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Height"      Value="6"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            SnapsToDevicePixels="True">
                        <Border x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="3"
                                    HorizontalAlignment="Left"/>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Separator ──────────────────────────────────────────────────────── -->
    <Style TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource Brush.Border}"/>
        <Setter Property="Margin"     Value="0,12"/>
        <Setter Property="Height"     Value="1"/>
    </Style>

    <!-- ── ScrollBar ──────────────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width"      Value="6"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         BUTTON STYLES
    ───────────────────────────────────────────────────────────────────────── -->

    <!-- Primary (teal fill) -->
    <Style x:Key="Btn.Primary" TargetType="Button">
        <Setter Property="Background"      Value="{StaticResource Brush.Accent}"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.OnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="{StaticResource Spacing.ButtonPad}"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Secondary (outlined) -->
    <Style x:Key="Btn.Secondary" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Accent}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Accent}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="{StaticResource Spacing.ButtonPad}"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.AccentLight}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost (no border, subtle hover) -->
    <Style x:Key="Btn.Ghost" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="8,5"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                            <Setter Property="Foreground"                  Value="{StaticResource Brush.Text.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger -->
    <Style x:Key="Btn.Danger" TargetType="Button" BasedOn="{StaticResource Btn.Primary}">
        <Setter Property="Background" Value="{StaticResource Brush.Danger}"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>

    <!-- Icon-only button (square) -->
    <Style x:Key="Btn.Icon" TargetType="Button" BasedOn="{StaticResource Btn.Ghost}">
        <Setter Property="Padding"  Value="6"/>
        <Setter Property="Width"    Value="30"/>
        <Setter Property="Height"   Value="30"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         CARD / PANEL
    ───────────────────────────────────────────────────────────────────────── -->

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="Background"     Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush"    Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"   Value="{StaticResource Radius.LG}"/>
        <Setter Property="Padding"        Value="{StaticResource Spacing.Card}"/>
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect Color="#000000" Opacity="0.055" BlurRadius="10" ShadowDepth="1" Direction="270"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="Card.Flat" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource Brush.Surface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource Radius.MD}"/>
        <Setter Property="Padding"         Value="12"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         STATUS BADGES
    ───────────────────────────────────────────────────────────────────────── -->

    <Style x:Key="Badge.Base" TargetType="Border">
        <Setter Property="CornerRadius"   Value="{StaticResource Radius.Pill}"/>
        <Setter Property="Padding"        Value="8,3"/>
    </Style>

    <Style x:Key="Badge.Success" TargetType="Border" BasedOn="{StaticResource Badge.Base}">
        <Setter Property="Background"     Value="{StaticResource Brush.SuccessLight}"/>
    </Style>

    <Style x:Key="Badge.Warning" TargetType="Border" BasedOn="{StaticResource Badge.Base}">
        <Setter Property="Background"     Value="{StaticResource Brush.WarningLight}"/>
    </Style>

    <Style x:Key="Badge.Danger" TargetType="Border" BasedOn="{StaticResource Badge.Base}">
        <Setter Property="Background"     Value="{StaticResource Brush.DangerLight}"/>
    </Style>

    <Style x:Key="Badge.Neutral" TargetType="Border" BasedOn="{StaticResource Badge.Base}">
        <Setter Property="Background"     Value="{StaticResource Brush.SurfaceAlt}"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         SIDEBAR NAV ITEM
    ───────────────────────────────────────────────────────────────────────── -->

    <Style x:Key="NavItem" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="12,10"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.MD}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="NavItem.Active" TargetType="Button" BasedOn="{StaticResource NavItem}">
        <Setter Property="Background" Value="{StaticResource Brush.AccentLight}"/>
        <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         TAB CONTROL
    ───────────────────────────────────────────────────────────────────────── -->

    <Style TargetType="TabControl">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style TargetType="TabItem">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="14,8"/>
        <Setter Property="FontFamily"      Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.MD}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            Padding="{TemplateBinding Padding}">
                        <Border x:Name="indicator"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Foreground"                  Value="{StaticResource Brush.Accent}"/>
                            <Setter Property="FontWeight"                  Value="SemiBold"/>
                            <Setter TargetName="indicator" Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         LIST / DATA GRID
    ───────────────────────────────────────────────────────────────────────── -->

    <Style TargetType="DataGrid">
        <Setter Property="Background"         Value="{StaticResource Brush.Surface}"/>
        <Setter Property="Foreground"         Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="BorderBrush"        Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness"    Value="1"/>
        <Setter Property="RowBackground"      Value="{StaticResource Brush.Surface}"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Brush.Background}"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Brush.Border}"/>
        <Setter Property="HeadersVisibility"  Value="Column"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="CanUserResizeRows"  Value="False"/>
        <Setter Property="FontFamily"         Value="{StaticResource Font.Body}"/>
        <Setter Property="FontSize"           Value="{StaticResource FontSize.MD}"/>
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background"      Value="{StaticResource Brush.SurfaceAlt}"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.SM}"/>
        <Setter Property="Padding"         Value="10,6"/>
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="BorderThickness" Value="0"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.AccentLight}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Brush.AccentLight}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         TOOLTIP
    ───────────────────────────────────────────────────────────────────────── -->

    <Style TargetType="ToolTip">
        <Setter Property="Background"      Value="{StaticResource Brush.Text.Primary}"/>
        <Setter Property="Foreground"      Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="8,4"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.SM}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource Radius.SM}"
                            Padding="{TemplateBinding Padding}">
                        <TextBlock Text="{TemplateBinding Content}"
                                   Foreground="White"
                                   FontSize="{StaticResource FontSize.SM}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         GROUP BOX / SECTION
    ───────────────────────────────────────────────────────────────────────── -->

    <Style TargetType="GroupBox">
        <Setter Property="BorderBrush"     Value="{StaticResource Brush.Border}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding"         Value="12"/>
        <Setter Property="Foreground"      Value="{StaticResource Brush.Text.Secondary}"/>
        <Setter Property="FontSize"        Value="{StaticResource FontSize.SM}"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         FORM FIELD HELPER
    ───────────────────────────────────────────────────────────────────────── -->

    <!-- Wraps label + input + optional error into a StackPanel-style unit -->
    <Style x:Key="FormField" TargetType="StackPanel">
        <Setter Property="Margin" Value="{StaticResource Spacing.SectionGap}"/>
    </Style>

    <!-- ─────────────────────────────────────────────────────────────────────
         STAT TILE  (used on dashboard header)
    ───────────────────────────────────────────────────────────────────────── -->

    <Style x:Key="StatTile" TargetType="Border" BasedOn="{StaticResource Card.Flat}">
        <Setter Property="Padding"  Value="14,10"/>
        <Setter Property="MinWidth" Value="120"/>
    </Style>

</ResourceDictionary>

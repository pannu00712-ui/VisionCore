<UserControl x:Class="VisionCore.WPF.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VisionCore.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:SettingsViewModel, IsDesignTimeCreatable=False}"
             Background="{StaticResource Brush.Background}"
             FontFamily="{StaticResource Font.Body}"
             FontSize="{StaticResource FontSize.MD}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <!-- ── Root grid: page header + two-column layout ─────────────────────── -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- page title + save/discard -->
            <RowDefinition Height="*"/>      <!-- content -->
        </Grid.RowDefinitions>

        <!-- ── Page header ──────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="28,16">
            <Grid>
                <StackPanel>
                    <TextBlock Text="Settings"
                               Style="{StaticResource Text.Heading}"/>
                    <TextBlock Text="Configure VisionCore behaviour, REST API, and streaming defaults."
                               Style="{StaticResource Text.Secondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">

                    <!-- Status message -->
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource Text.Secondary}"
                               VerticalAlignment="Center"
                               Margin="0,0,16,0"/>

                    <Button Content="Discard"
                            Style="{StaticResource Btn.Secondary}"
                            Command="{Binding DiscardCommand}"
                            MinWidth="80"
                            Margin="0,0,8,0"/>
                    <Button Content="Save settings"
                            Style="{StaticResource Btn.Primary}"
                            Command="{Binding SaveCommand}"
                            MinWidth="120"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Content area: two columns ────────────────────────────────────── -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="28,24,28,28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ── LEFT COLUMN ──────────────────────────────────────────── -->
                <StackPanel Grid.Column="0">

                    <!-- ── General ─────────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="GENERAL"
                                       Style="{StaticResource Text.SectionHeader}"/>

                            <StackPanel Style="{StaticResource FormField}">
                                <TextBlock Text="Theme" Style="{StaticResource Text.Label}"/>
                                <ComboBox ItemsSource="{Binding ThemeOptions}"
                                          SelectedItem="{Binding Theme}"/>
                            </StackPanel>

                            <CheckBox Content="Start with Windows"
                                      IsChecked="{Binding StartWithWindows}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Run as background service"
                                      IsChecked="{Binding RunAsService}"
                                      Margin="0,0,0,10"/>

                            <CheckBox Content="Minimize to tray icon"
                                      IsChecked="{Binding MinimizeToTray}"/>
                        </StackPanel>
                    </Border>


                    <!-- ── ONVIF Mode ──────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="ONVIF MODE"
                                       Style="{StaticResource Text.SectionHeader}"/>

                            <StackPanel Style="{StaticResource FormField}">
                                <TextBlock Text="Camera exposure mode" Style="{StaticResource Text.Label}"/>
                                <ComboBox ItemsSource="{Binding OnvifModeOptions}"
                                          SelectedItem="{Binding OnvifMode}"/>
                                <TextBlock TextWrapping="Wrap"
                                           Style="{StaticResource Text.Secondary}"
                                           Margin="0,5,0,0">
                                    <Run FontWeight="SemiBold">Multiple Camera</Run>
                                    <Run>— each camera gets its own ONVIF IP address and port (e.g. 8080, 8081). NVR discovers N separate cameras.</Run>
                                </TextBlock>
                                <TextBlock TextWrapping="Wrap"
                                           Style="{StaticResource Text.Secondary}"
                                           Margin="0,4,0,0">
                                    <Run FontWeight="SemiBold">Multiple Channel</Run>
                                    <Run>— all cameras share one ONVIF IP address on a single port. NVR discovers one camera with N channels/profiles.</Run>
                                </TextBlock>
                            </StackPanel>

                            <!-- Shared port — only shown in Multiple Channel mode -->
                            <StackPanel Style="{StaticResource FormField}"
                                        Visibility="{Binding IsSharedPortVisible,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Shared ONVIF port" Style="{StaticResource Text.Label}"/>
                                <TextBox Text="{Binding OnvifSharedPort, UpdateSourceTrigger=PropertyChanged}"
                                         ToolTip="HTTP port for the shared ONVIF listener (default 8090)"/>
                            </StackPanel>

                            <TextBlock Text="⚠ Changes take effect after restarting the service."
                                       Style="{StaticResource Text.Secondary}"
                                       Foreground="{StaticResource Brush.Warning}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <!-- ── Logging ──────────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="LOGGING"
                                       Style="{StaticResource Text.SectionHeader}"/>

                            <StackPanel Style="{StaticResource FormField}">
                                <TextBlock Text="Minimum log level" Style="{StaticResource Text.Label}"/>
                                <ComboBox ItemsSource="{Binding LogLevelOptions}"
                                          SelectedItem="{Binding LogLevel}"/>
                            </StackPanel>

                            <Separator/>

                            <Grid>
                                <StackPanel>
                                    <TextBlock Text="Log folder" Style="{StaticResource Text.Label}"/>
                                    <TextBlock Text="{Binding LogFolder}"
                                               Style="{StaticResource Text.Mono}"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource Brush.Text.Secondary}"/>
                                </StackPanel>
                                <Button Content="Open"
                                        Style="{StaticResource Btn.Ghost}"
                                        Command="{Binding OpenLogFolderCommand}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- ── Backup & Migration ───────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="BACKUP &amp; MIGRATION"
                                       Style="{StaticResource Text.SectionHeader}"/>

                            <TextBlock Text="Export all app settings and camera configurations to a JSON file, or import a previously exported file. Useful for backups or replicating setup across multiple PCs."
                                       Style="{StaticResource Text.Secondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,12"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Export configuration…"
                                        Style="{StaticResource Btn.Secondary}"
                                        Command="{Binding ExportConfigCommand}"
                                        Margin="0,0,8,0"/>
                                <Button Content="Import configuration…"
                                        Style="{StaticResource Btn.Ghost}"
                                        Command="{Binding ImportConfigCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>

                <!-- ── RIGHT COLUMN ─────────────────────────────────────────── -->
                <StackPanel Grid.Column="2">

                    <!-- ── REST API ─────────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="REST API"
                                           Style="{StaticResource Text.SectionHeader}"
                                           VerticalAlignment="Center"
                                           Margin="0"/>
                                <CheckBox Content="Enabled"
                                          IsChecked="{Binding RestApiEnabled}"
                                          HorizontalAlignment="Right"
                                          VerticalAlignment="Center"/>
                            </Grid>

                            <StackPanel Style="{StaticResource FormField}"
                                        IsEnabled="{Binding RestApiEnabled}">
                                <TextBlock Text="Port" Style="{StaticResource Text.Label}"/>
                                <TextBox Text="{Binding RestApiPort, UpdateSourceTrigger=PropertyChanged}"
                                         Width="140" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <!-- Endpoint URLs -->
                            <StackPanel Margin="0,0,0,12"
                                        IsEnabled="{Binding RestApiEnabled}">
                                <TextBlock Text="Base URL" Style="{StaticResource Text.Label}"/>
                                <TextBlock Text="{Binding ApiBaseUrl}"
                                           Style="{StaticResource Text.Mono}"/>
                            </StackPanel>

                            <Separator/>

                            <!-- API token -->
                            <StackPanel IsEnabled="{Binding RestApiEnabled}">
                                <TextBlock Text="API token" Style="{StaticResource Text.Label}"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Style="{StaticResource Card.Flat}"
                                            CornerRadius="4,0,0,4"
                                            Padding="8,6"
                                            Margin="0,0,0,0">
                                        <TextBlock Text="{Binding TokenMasked}"
                                                   Style="{StaticResource Text.Mono}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Border>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource Btn.Ghost}"
                                            Command="{Binding ToggleTokenCommand}"
                                            ToolTip="Show / hide token"
                                            Margin="4,0,0,0">
                                        <TextBlock Text="👁" FontSize="14"/>
                                    </Button>

                                    <Button Grid.Column="2"
                                            Style="{StaticResource Btn.Ghost}"
                                            Command="{Binding CopyTokenCommand}"
                                            ToolTip="Copy token to clipboard"
                                            Margin="2,0,0,0">
                                        <TextBlock Text="⎘" FontSize="14"/>
                                    </Button>

                                    <Button Grid.Column="3"
                                            Style="{StaticResource Btn.Secondary}"
                                            Command="{Binding RegenerateTokenCommand}"
                                            Content="Regenerate"
                                            Margin="4,0,0,0"
                                            ToolTip="Generate a new random token"/>
                                </Grid>
                            </StackPanel>

                            <Separator/>

                            <!-- Test + Swagger -->
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <Button Content="Test connection"
                                        Style="{StaticResource Btn.Secondary}"
                                        Command="{Binding TestApiCommand}"
                                        IsEnabled="{Binding RestApiEnabled}"
                                        MinWidth="120"/>
                                <Button Content="Open Swagger"
                                        Style="{StaticResource Btn.Ghost}"
                                        Command="{Binding OpenSwaggerCommand}"
                                        IsEnabled="{Binding RestApiEnabled}"
                                        Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- Test result -->
                            <TextBlock Text="{Binding ApiTestResult}"
                                       Style="{StaticResource Text.Secondary}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding ApiTestResult,
                                                    Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Border>

                    <!-- ── MediaMTX ──────────────────────────────────────────── -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <TextBlock Text="MEDIAMTX"
                                           Style="{StaticResource Text.SectionHeader}"
                                           VerticalAlignment="Center"
                                           Margin="0"/>

                                <!-- Installed badge -->
                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Center">
                                    <Border.Style>
                                        <Style TargetType="Border" BasedOn="{StaticResource Badge.Success}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MediaMtxInstalled}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource Brush.WarningLight}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Installed"/>
                                                <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                                                <Setter Property="FontSize"   Value="{StaticResource FontSize.SM}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding MediaMtxInstalled}" Value="False">
                                                        <Setter Property="Text"       Value="Not installed"/>
                                                        <Setter Property="Foreground" Value="{StaticResource Brush.Warning}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <!-- Path -->
                            <StackPanel Margin="0,0,0,12"
                                        Visibility="{Binding MediaMtxInstalled,
                                                     Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Binary path" Style="{StaticResource Text.Label}"/>
                                <TextBlock Text="{Binding MediaMtxPath}"
                                           Style="{StaticResource Text.Mono}"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource Brush.Text.Secondary}"/>
                            </StackPanel>

                            <!-- Download progress -->
                            <StackPanel Visibility="{Binding IsDownloading,
                                                     Converter={StaticResource BoolToVis}}"
                                        Margin="0,0,0,12">
                                <ProgressBar Value="{Binding DownloadProgress}"
                                             Maximum="100"
                                             Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding DownloadMessage}"
                                           Style="{StaticResource Text.Secondary}"/>
                            </StackPanel>

                            <Button Content="Download MediaMTX"
                                    Style="{StaticResource Btn.Secondary}"
                                    Command="{Binding DownloadMediaMtxCommand}"
                                    IsEnabled="{Binding IsDownloading,
                                               Converter={StaticResource BoolToVis},
                                               ConverterParameter=Inverse}"
                                    MinWidth="160"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>

<Window x:Class="VisionCore.WPF.Views.LicenseView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:VisionCore.WPF.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:LicenseViewModel}"
        Title="License Activation"
        Width="500" Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{StaticResource Brush.Background}">

    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="Auto"/>   <!-- Current license card -->
            <RowDefinition Height="Auto"/>   <!-- Divider -->
            <RowDefinition Height="Auto"/>   <!-- Activate section -->
            <RowDefinition Height="*"/>      <!-- Spacer -->
            <RowDefinition Height="Auto"/>   <!-- Status / error -->
            <RowDefinition Height="Auto"/>   <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- ── Header ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="License"
                       Style="{StaticResource Text.Heading}"
                       FontSize="{StaticResource FontSize.2XL}"
                       Margin="0,0,0,4"/>
            <TextBlock Text="Activate VisionCore Pro to unlock recording, scheduling, and the REST API."
                       Style="{StaticResource Text.Secondary}"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <!-- ── Current license card ───────────────────────────────────────── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Tier badge -->
                <StackPanel Grid.Row="0" Grid.Column="0"
                            Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Current tier: "
                               Style="{StaticResource Text.Secondary}"/>
                    <Border Padding="8,2,8,2" CornerRadius="{StaticResource Radius.Pill}"
                            Margin="4,0,0,0">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource Badge.Base}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsPro}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource Brush.AccentLight}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Accent}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsPro}" Value="False">
                                        <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding TierLabel}" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSize.SM}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsPro}" Value="True">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Accent}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsPro}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                </StackPanel>

                <!-- Customer name -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{Binding CustomerName}"
                           Style="{StaticResource Text.Primary}"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Visibility="{Binding IsPro, Converter={StaticResource BoolToVis}}"/>

                <!-- Expiry -->
                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{Binding ExpiryLabel}"
                           Style="{StaticResource Text.Secondary}"
                           FontSize="{StaticResource FontSize.SM}"/>

                <!-- Deactivate button (Pro only) -->
                <Button Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                        Content="Deactivate"
                        Style="{StaticResource Btn.Ghost}"
                        Command="{Binding DeactivateCommand}"
                        VerticalAlignment="Center"
                        Visibility="{Binding IsPro, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- ── Divider ─────────────────────────────────────────────────────── -->
        <Separator Grid.Row="2" Margin="0,0,0,16"
                   Background="{StaticResource Brush.Border}"/>

        <!-- ── Activate section ───────────────────────────────────────────── -->
        <StackPanel Grid.Row="3" Margin="0,0,0,0">
            <TextBlock Text="Enter license key"
                       Style="{StaticResource Text.Label}"
                       Margin="0,0,0,6"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding LicenseKey, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsActivating, Converter={StaticResource InvertBool}}"
                         FontFamily="{StaticResource Font.Mono}"
                         FontSize="{StaticResource FontSize.SM}"
                         Padding="{StaticResource Spacing.Input}"
                         CharacterCasing="Upper"
                         VerticalContentAlignment="Center"
                         Margin="0,0,8,0"
                         ToolTip="Paste your license key here"/>

                <Button Grid.Column="1"
                        Content="Activate"
                        Style="{StaticResource Btn.Primary}"
                        Command="{Binding ActivateCommand}"
                        MinWidth="100">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Activating…"
                                           Visibility="{Binding DataContext.IsActivating,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource BoolToVis}}"/>
                                <TextBlock Text="Activate"
                                           Visibility="{Binding DataContext.IsActivating,
                                               RelativeSource={RelativeSource AncestorType=Window},
                                               Converter={StaticResource InvertBoolToVis}}"/>
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </Grid>

            <!-- Progress indicator while activating -->
            <ProgressBar IsIndeterminate="True"
                         Height="2"
                         Margin="0,0,0,8"
                         Visibility="{Binding IsActivating, Converter={StaticResource BoolToVis}}"/>

            <!-- Feature comparison (shown when not Pro) -->
            <Border Style="{StaticResource Card.Flat}"
                    Visibility="{Binding IsPro, Converter={StaticResource InvertBoolToVis}}"
                    Margin="0,4,0,0">
                <StackPanel>
                    <TextBlock Text="VisionCore Pro includes:"
                               Style="{StaticResource Text.Label}"
                               Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="✓" Foreground="{StaticResource Brush.Success}" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="Unlimited cameras" Style="{StaticResource Text.Secondary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="✓" Foreground="{StaticResource Brush.Success}" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="Local MP4 recording" Style="{StaticResource Text.Secondary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="✓" Foreground="{StaticResource Brush.Success}" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="Schedule-based start / stop" Style="{StaticResource Text.Secondary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                        <TextBlock Text="✓" Foreground="{StaticResource Brush.Success}" FontWeight="Bold" Margin="0,0,8,0"/>
                        <TextBlock Text="REST API access" Style="{StaticResource Text.Secondary}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ── Status / error message ─────────────────────────────────────── -->
        <Border Grid.Row="5" Margin="0,12,0,12"
                Padding="10,8"
                CornerRadius="{StaticResource Radius.MD}"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringToVis}}">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasError}" Value="True">
                            <Setter Property="Background" Value="{StaticResource Brush.DangerLight}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Danger}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding HasError}" Value="False">
                            <Setter Property="Background" Value="{StaticResource Brush.SuccessLight}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Success}"/>
                            <Setter Property="BorderThickness" Value="1"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding StatusMessage}"
                       TextWrapping="Wrap">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasError}" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Danger}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding HasError}" Value="False">
                                <Setter Property="Foreground" Value="{StaticResource Brush.Success}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </Border>

        <!-- ── Buttons ────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Close"
                    Style="{StaticResource Btn.Secondary}"
                    Command="{Binding CancelCommand}"
                    MinWidth="90"/>
        </StackPanel>
    </Grid>
</Window>

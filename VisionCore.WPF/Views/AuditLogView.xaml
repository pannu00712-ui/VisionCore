<UserControl x:Class="VisionCore.WPF.Views.AuditLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:VisionCore.WPF.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:AuditLogViewModel, IsDesignTimeCreatable=False}"
             Background="{StaticResource Brush.Background}"
             FontFamily="{StaticResource Font.Body}"
             FontSize="{StaticResource FontSize.MD}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- toolbar -->
            <RowDefinition Height="*"/>     <!-- audit table -->
            <RowDefinition Height="Auto"/>  <!-- status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ───────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- page title -->
                    <ColumnDefinition Width="*"/>     <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- action buttons -->
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Audit Log"
                               Style="{StaticResource Text.Heading}"/>
                    <TextBlock Text="Who changed what, and when — camera and settings changes are recorded automatically."
                               Style="{StaticResource Text.Secondary}"
                               Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="Refresh"
                            Style="{StaticResource Btn.Secondary}"
                            Command="{Binding RefreshCommand}"
                            Margin="0,0,8,0"/>
                    <Button Content="Export CSV…"
                            Style="{StaticResource Btn.Ghost}"
                            Command="{Binding ExportCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Audit table ───────────────────────────────────────────────────── -->
        <ListView Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  BorderThickness="0"
                  Background="{StaticResource Brush.Background}"
                  FontSize="{StaticResource FontSize.SM}"
                  SelectionMode="Single"
                  AlternationCount="2">

            <ListView.View>
                <GridView>
                    <!-- Time -->
                    <GridViewColumn Header="Time" Width="160">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TimestampLocal, StringFormat='{}{0:yyyy-MM-dd  HH:mm:ss}'}"
                                           FontFamily="{StaticResource Font.Mono}"
                                           Foreground="{StaticResource Brush.Text.Secondary}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- User -->
                    <GridViewColumn Header="User" Width="140"
                                    DisplayMemberBinding="{Binding Username}"/>

                    <!-- Action -->
                    <GridViewColumn Header="Action" Width="160">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource Brush.AccentLight}"
                                        CornerRadius="3"
                                        Padding="6,1"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Action}"
                                               Foreground="{StaticResource Brush.Accent}"
                                               FontSize="{StaticResource FontSize.XS}"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>

                    <!-- Target -->
                    <GridViewColumn Header="Target" Width="180"
                                    DisplayMemberBinding="{Binding Target}"/>

                    <!-- Details -->
                    <GridViewColumn Header="Details" Width="320"
                                    DisplayMemberBinding="{Binding Details}"/>
                </GridView>
            </ListView.View>

            <ListView.Resources>
                <Style TargetType="GridViewColumnHeader">
                    <Setter Property="Background" Value="{StaticResource Brush.Surface}"/>
                    <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}"/>
                    <Setter Property="FontWeight"  Value="SemiBold"/>
                    <Setter Property="Padding"     Value="8,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="8,4"/>
                    <Style.Triggers>
                        <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                            <Setter Property="Background" Value="{StaticResource Brush.SurfaceAlt}"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.Resources>
        </ListView>

        <!-- ── Empty state ──────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Entries.Count}" Value="0">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="No audit entries yet."
                       Style="{StaticResource Text.Secondary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Camera and settings changes will appear here."
                       Style="{StaticResource Text.Secondary}"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- ── Status bar ───────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="{Binding StatusMessage}"
                       Style="{StaticResource Text.Secondary}"
                       FontSize="{StaticResource FontSize.SM}"/>
        </Border>
    </Grid>
</UserControl>

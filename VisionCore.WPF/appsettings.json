{
  // ═══════════════════════════════════════════════════════════════════════════
  // VisionCore Service — appsettings.json
  //
  // Embedded in the VisionCore.Service publish output.
  // Values here are defaults; override with appsettings.Production.json or
  // environment variables (prefix: VisionCore__) or command-line args.
  //
  // ⚠ This file is marked NeverOverwrite in the installer — your local edits
  //   survive upgrades.
  // ═══════════════════════════════════════════════════════════════════════════

  // ── Serilog ─────────────────────────────────────────────────────────────
  "Serilog": {
    "Using": [
      "Serilog.Sinks.File",
      "Serilog.Sinks.EventLog",
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System.Net.Http": "Warning"
      }
    },
    "WriteTo": [
      {
        // Rolling file — one per day, kept 7 days
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%/VisionCore/logs/service-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        // Windows Event Log — visible in Event Viewer under Application
        "Name": "EventLog",
        "Args": {
          "source": "VisionCore",
          "logName": "Application",
          "restrictedToMinimumLevel": "Warning"
        }
      },
      {
        // Console — active when running interactively (debug / sc.exe start + attach)
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },

  // ── VisionCore engine defaults ───────────────────────────────────────────
  // These mirror AppSettings.cs property defaults.
  // The service reads AppSettings from SQLite (via SettingsService), NOT from
  // this file.  These values are fallbacks for keys the service host itself
  // reads via IConfiguration (e.g. port numbers before SQLite is initialised).
  "VisionCore": {

    // RTSP server (MediaMTX)
    "RtspPort": 8554,

    // Embedded REST API
    "RestApiEnabled": true,
    "RestApiPort": 7880,

    // Auto-start all enabled cameras when the service starts
    "AutoStartCameras": true,

    // Update checker
    "AutoCheckUpdates": true,
    "UpdateManifestUrl": "https://updates.visioncore.app/manifest.json",

    // IPC named pipe (matches ServiceConstants.IpcPipeName)
    "IpcPipeName": "VisionCoreServicePipe",

    // Shutdown timeout for the Generic Host (seconds)
    // Increase if cameras are slow to stop
    "ShutdownTimeoutSeconds": 30
  },

  // ── Host lifetime ────────────────────────────────────────────────────────
  "HostOptions": {
    // Must be >= VisionCore:ShutdownTimeoutSeconds
    "ShutdownTimeout": "00:00:30"
  },

  // ── Logging level switch (runtime-adjustable) ────────────────────────────
  // Serilog.Settings.Configuration reads this key when a LoggingLevelSwitch
  // is wired up in Program.cs.  Changing this in appsettings.Production.json
  // and sending SIGHUP / restarting the service applies the new level.
  "LoggingLevelSwitches": {
    "$controlSwitch": "Information"
  }
}

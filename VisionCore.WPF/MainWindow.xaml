<Window x:Class="VisionCore.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:VisionCore.WPF.Views"
        mc:Ignorable="d"
        Title="VisionCore"
        Width="1280" Height="780"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Style="{StaticResource WindowBase}">

    <!-- ── Root: sidebar + content ────────────────────────────────────────── -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>          <!-- sidebar -->
            <ColumnDefinition Width="*"/>            <!-- page area -->
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════════
             SIDEBAR
        ═══════════════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0"
                Background="{StaticResource Brush.Surface}"
                BorderBrush="{StaticResource Brush.Border}"
                BorderThickness="0,0,1,0">
            <DockPanel>

                <!-- Branding -->
                <Border DockPanel.Dock="Top"
                        Padding="20,20,20,12"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="VisionCore"
                                   FontSize="{StaticResource FontSize.LG}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource Brush.Accent}"/>
                        <TextBlock Text="Streaming Engine"
                                   Style="{StaticResource Text.Secondary}"
                                   Margin="0,1,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Version + status at bottom -->
                <Border DockPanel.Dock="Bottom"
                        Padding="16,10"
                        BorderBrush="{StaticResource Brush.Border}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <!-- RTSP indicator -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="7" Height="7"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Success}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RtspServerOnline}" Value="False">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="RTSP" Style="{StaticResource Text.Secondary}"/>
                        </StackPanel>
                        <!-- REST API indicator -->
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource Brush.Success}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding RestApiOnline}" Value="False">
                                                <Setter Property="Fill" Value="{StaticResource Brush.Danger}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>
                            <TextBlock Text="REST API" Style="{StaticResource Text.Secondary}"/>
                        </StackPanel>

                        <TextBlock x:Name="VersionText"
                                   Text="v1.0.0"
                                   Style="{StaticResource Text.Secondary}"
                                   Margin="0,8,0,0"
                                   FontSize="{StaticResource FontSize.XS}"/>
                    </StackPanel>
                </Border>

                <!-- Nav items -->
                <StackPanel DockPanel.Dock="Top"
                            Margin="8,12,8,0">

                    <Button x:Name="NavDashboard"
                            Content="📹  Dashboard"
                            Style="{StaticResource NavItem.Active}"
                            Click="NavDashboard_Click"
                            Margin="0,0,0,2"/>

                    <Button x:Name="NavLogs"
                            Content="📋  Logs"
                            Style="{StaticResource NavItem}"
                            Click="NavLogs_Click"
                            Margin="0,0,0,2"/>

                    <Button x:Name="NavSettings"
                            Content="⚙  Settings"
                            Style="{StaticResource NavItem}"
                            Click="NavSettings_Click"
                            Margin="0,0,0,2"/>

                    <Button x:Name="NavAuditLog"
                            Content="🛡  Audit Log"
                            Style="{StaticResource NavItem}"
                            Click="NavAuditLog_Click"
                            Margin="0,0,0,2"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════════
             PAGE HOST
        ═══════════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>   <!-- status bar -->
            </Grid.RowDefinitions>

            <!-- Pages — only one visible at a time -->
            <views:DashboardView x:Name="PageDashboard"
                                 Grid.Row="0"/>

            <views:LogsView     x:Name="PageLogs"
                                Grid.Row="0"
                                Visibility="Collapsed"/>

            <views:SettingsView x:Name="PageSettings"
                                Grid.Row="0"
                                Visibility="Collapsed"/>

            <views:AuditLogView x:Name="PageAuditLog"
                                Grid.Row="0"
                                Visibility="Collapsed"/>

            <!-- Status bar -->
            <Border Grid.Row="1"
                    Background="{StaticResource Brush.Surface}"
                    BorderBrush="{StaticResource Brush.Border}"
                    BorderThickness="0,1,0,0"
                    Padding="16,5">
                <Grid>
                    <TextBlock Text="{Binding StatusMessage}"
                               Style="{StaticResource Text.Secondary}"
                               VerticalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource Text.Secondary}">
                            <Run Text="{Binding ActiveCameras, Mode=OneWay}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding TotalCameras, Mode=OneWay}"/>
                            <Run Text=" cameras  ·  "/>
                            <Run Text="{Binding TotalClients, Mode=OneWay}"/>
                            <Run Text=" clients  ·  "/>
                            <Run Text="{Binding TotalBitrateKbps, Mode=OneWay, StringFormat='{}{0:N0}'}"/>
                            <Run Text=" kbps  ·  "/>
                            <Run Text="{Binding AppUptime, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
